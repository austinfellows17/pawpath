# Staging — copy to .env.staging for local staging work, or set in Vercel Preview env.

NEXTAUTH_URL="https://pawpath-staging.vercel.app"
NEXTAUTH_SECRET="staging-secret-change-me"

DATABASE_URL="postgresql://postgres.[STAGING-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[STAGING-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_MAPBOX_TOKEN=""
SENTRY_DSN=""

# Stripe test mode
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_FEATURED=""
STRIPE_PRICE_BACKGROUND_CHECK=""

SUPABASE_URL="https://[STAGING-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_VERIFICATION_BUCKET="verification-documents"
SUPABASE_PROFILE_PHOTOS_BUCKET="profile-photos"
SUPABASE_CREDENTIALS_BUCKET="walker-credentials"

RESEND_API_KEY=""
EMAIL_FROM="PawPath Staging <onboarding@resend.dev>"

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Feature flags
NEXT_PUBLIC_SHOW_BETA_BANNER="true"
REQUIRE_EMAIL_VERIFICATION="true"
