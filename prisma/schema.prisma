generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  WALKER
  ADMIN
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingTier {
  BASIC
  STANDARD
  FEATURED
}

enum MessageStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(OWNER)
  termsAcceptedAt DateTime?
  notificationEmailEnabled Boolean @default(true)
  notificationSmsEnabled   Boolean @default(false)
  notificationPhone        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  ownerProfile  OwnerProfile?
  walkerProfile WalkerProfile?
  ownerConversations  Conversation[] @relation("OwnerConversations")
  walkerConversations Conversation[] @relation("WalkerConversations")
  sentMessages  Message[]     @relation("SentMessages")
  reviews       Review[]
  adminActions  AdminAction[]
  adminReviewInquiries  ReviewInquiry[] @relation("AdminReviewInquiries")
  authorReviewInquiries ReviewInquiry[] @relation("AuthorReviewInquiries")
  reviewInquiryMessages ReviewInquiryMessage[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OwnerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  zipCode     String
  city        String?
  neighborhood String?
  latitude    Float
  longitude   Float
  dogName     String?
  dogBreed    String?
  dogNotes    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@index([zipCode])
  @@map("owner_profiles")
}

model WalkerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  headline           String
  bio                String             @db.Text
  services           String[]
  rate30Min          String?
  rate60Min          String?
  zipCode            String
  city               String?
  neighborhood       String?
  latitude           Float
  longitude          Float
  serviceRadiusMiles Float              @default(5)
  phone              String?
  email              String?
  listingTier        ListingTier        @default(BASIC)
  tierExpiresAt      DateTime?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeSubscriptionStatus String?
  verificationStatus VerificationStatus @default(NONE)
  verificationDocStoragePath String?
  verificationDocMimeType String?
  verificationDocFileName String?
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  verificationNotes       String?        @db.Text
  isActive           Boolean            @default(true)
  photoUrls          String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([latitude, longitude])
  @@index([zipCode])
  @@index([listingTier])
  @@index([verificationStatus])
  @@map("walker_profiles")
}

model Conversation {
  id              String   @id @default(cuid())
  ownerId         String
  walkerUserId    String
  contactRevealed Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner    User      @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  walker   User      @relation("WalkerConversations", fields: [walkerUserId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([ownerId, walkerUserId])
  @@index([ownerId])
  @@index([walkerUserId])
  @@map("conversations")
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  body           String        @db.Text
  status         MessageStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Review {
  id              String       @id @default(cuid())
  authorId        String
  walkerProfileId String
  rating          Int
  body            String       @db.Text
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  walkerProfile WalkerProfile @relation(fields: [walkerProfileId], references: [id], onDelete: Cascade)
  inquiry       ReviewInquiry?

  @@unique([authorId, walkerProfileId])
  @@index([walkerProfileId, status])
  @@map("reviews")
}

model ReviewInquiry {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  adminId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review   Review                 @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  admin    User                   @relation("AdminReviewInquiries", fields: [adminId], references: [id], onDelete: Cascade)
  author   User                   @relation("AuthorReviewInquiries", fields: [authorId], references: [id], onDelete: Cascade)
  messages ReviewInquiryMessage[]

  @@index([authorId])
  @@map("review_inquiries")
}

model ReviewInquiryMessage {
  id        String   @id @default(cuid())
  inquiryId String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  inquiry ReviewInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender  User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@map("review_inquiry_messages")
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_actions")
}
