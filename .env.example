# Database (Supabase PostgreSQL)
# Use the Transaction pooler URL for the app (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the Session pooler URL for Prisma migrations/db push (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# OAuth providers (Google sign-in)
# Run: npx tsx scripts/google-oauth-setup.ts
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Mapbox (for map view and geocoding)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Stripe (walker listing tiers)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Create monthly prices in Stripe Dashboard, then paste Price IDs here:
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_FEATURED=""
# One-time $50 background check add-on (Summit/Peak):
# Run: npm run stripe:bg-addon-setup
STRIPE_PRICE_BACKGROUND_CHECK=""

# Checkr (optional — manual admin review without API key)
# Run: npm run checkr:setup
CHECKR_API_KEY=""
CHECKR_PACKAGE_SLUG="tasker_standard"

# Supabase Storage (walker verification documents)
# Run: npx tsx scripts/supabase-storage-setup.ts
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_VERIFICATION_BUCKET="verification-documents"

# Email notifications (Resend)
# Run: npx tsx scripts/notifications-setup.ts
RESEND_API_KEY=""
EMAIL_FROM="PawPath <onboarding@resend.dev>"

# SMS notifications (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
